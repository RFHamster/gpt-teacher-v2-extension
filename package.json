{
  "name": "gpt-teacher",
  "displayName": "gpt-teacher",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gpt-teacher-sidebar",
          "title": "GPT Teacher",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "gpt-teacher-sidebar": [
        {
          "type": "webview",
          "id": "gpt-teacher-sidebar-view",
          "name": "GPT Teacher"
        }
      ]
    },
    "commands": [
      {
        "command": "gpt-teacher.login",
        "title": "GPT Teacher: Login"
      },
      {
        "command": "gpt-teacher.logout",
        "title": "GPT Teacher: Logout",
        "icon": "$(sign-out)"
      },
      {
        "command": "gpt-teacher.refreshItems",
        "title": "Refresh Items",
        "icon": "$(refresh)"
      },
      {
        "command": "gpt-teacher.openItem",
        "title": "Open Item"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gpt-teacher.refreshItems",
          "when": "view == gpt-teacher-items",
          "group": "navigation"
        },
        {
          "command": "gpt-teacher.logout",
          "when": "view == gpt-teacher-items",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "esbuild": "^0.27.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
